<% layout("/layouts/boilerplate")  %>
</head>
<body>  
<div class="form-container">
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" enctype="multipart/form-data">
        <div>
    
    <h3>Edit Listing</h3>

<div class="mb-3">
    <label for="title" class="form-label">Title</label>
        <input value="<%= listing.title %>" type="text"
         name="listing[title]" placeholder="title" class="form-control" required>
         
      <div class="invalid-feedback"> please enter the valid title</div>
    </div>
       

       <div class="mb-3"> 
        <label for="Description" class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required>
        <%= listing.description %></textarea >
          <div class="invalid-feedback"> please enter the short description</div>
    </div>
    </div>
      
      
    <div  class="row mt-3  col-6 offset-2  "   >
      <h4>Original image</h4>
      <img src="<%= listing.image.url %>" >
    </div>
        <div class="mb-3">
            <label for="image" class="form-label"> Upload New Image</label>
        <input 
        type="file" 
        name="listing[image]" 
        placeholder="Upload New Image" class="form-control">
        
    </div>
      
      <div class="mb-3">
          <label for="price" class="form-label">Price</label>
        <input type="number" value="<%= listing.price %>" 
        name="listing[price]" placeholder="Price" class="form-control" required>
      </div>
        
        <div class="mb-3">
             <label for="location" class="form-label">Location</label>
        <input type="text" value="<%= listing.location %>" 
        name="listing[location]" placeholder="Location" class="form-control" required>
        </div>
     
      <div class="mb-3">
          <label for="country" class="form-label">Country</label>
        <input type="text" value="<%= listing.country %>" 
        name="listing[country]" placeholder="Country" class="form-control" required>
      </div>
      <!-- Add this inside the listing form in both new.ejs and edit.ejs -->
<div class="mb-3">
  <label class="form-label" for="category">Category</label>
  <select name="listing[category]" id="category" class="form-select">
    <option value="Trending">Trending</option>
    <option value="Mountains">Mountains</option>
    <option value="Beach">Beach</option>
    <option value="Arctic">Arctic</option>
    <option value="Rooms">Rooms</option>
    <option value="Amazing Pools">Amazing Pools</option>
    <option value="Cabins">Cabins</option>
    <option value="Farms">Farms</option>
    <option value="Iconic Cities">Iconic Cities</option>
    <option value="Lake View">Lake View</option>
    <option value="Old">Old</option>
    <option value="Snow">Snow</option>
  </select>
</div>

      <div class="container">
        <button type="submit" class="button-17" class="btn-ctr">Update</button>

    </div>

        
    </form>
    </div>
    
</body>

